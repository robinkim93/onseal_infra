# Onseal M1 환경변수 예시 — 복사: cp .env.example .env
# ⚠️ 에어갭 원칙: 여기에 외부 API 키/엔드포인트가 들어가면 안 된다. 전부 사내망/로컬.

# --- Postgres (pgvector) ---
POSTGRES_USER=onseal
POSTGRES_PASSWORD=change-me
POSTGRES_DB=onseal
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Ollama (로컬 LLM 서빙) ---
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b          # M1 개발용 소형 모델 (한국어 후보, M2에서 벤치/교체)

# --- 임베딩 (로컬) ---
EMBEDDING_MODEL=BAAI/bge-m3       # 로컬 한국어 임베딩 (M1 확정, M2 벤치/교체)
EMBEDDING_DIM=1024                # bge-m3 차원 — init_db.sql 의 VECTOR(N)과 반드시 일치
