# Onseal M1 환경변수 예시 — 복사: cp .env.example .env
# ⚠️ 에어갭 원칙: 여기에 외부 API 키/엔드포인트가 들어가면 안 된다. 전부 사내망/로컬.

# --- Postgres (pgvector) ---
POSTGRES_USER=onseal
POSTGRES_PASSWORD=change-me
POSTGRES_DB=onseal
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Ollama (로컬 LLM 서빙) ---
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b          # M1 개발용 소형 모델 (한국어 후보, M2에서 벤치/교체)

# --- 임베딩 (로컬) ---
EMBEDDING_MODEL=                  # TODO: 로컬 한국어 임베딩 모델명 — 직접 선택
EMBEDDING_DIM=                    # TODO: 위 모델의 벡터 차원 (pgvector 스키마와 일치해야 함)
